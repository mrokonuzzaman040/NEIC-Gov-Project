# Production Environment Configuration Template
# Copy this file to .env.production and update the values

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NODE_ENV=production
APP_NAME="BD Election Commission Portal"
APP_URL="https://neic-bd.org"

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://election_user:CHANGE_THIS_PASSWORD@localhost:5432/election_portal"

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Redis connection URL for caching and rate limiting
REDIS_URL="redis://localhost:6379"

# ===========================================
# NEXT.JS & NEXT-AUTH CONFIGURATION
# ===========================================
NEXTAUTH_URL="https://neic-bd.org"
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_SECURE_RANDOM_STRING"

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
MAX_FILE_SIZE="25MB"
UPLOAD_DIR="/opt/election-portal/uploads"

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
ENABLE_RATE_LIMITING="true"
RATE_LIMIT_WINDOW="15"
RATE_LIMIT_MAX_REQUESTS="100"

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# Configure these with your SMTP provider (e.g., SendGrid, AWS SES, etc.)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@neic-bd.org"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@neic-bd.org"

# ===========================================
# RECAPTCHA CONFIGURATION
# ===========================================
# Get these from https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY="YOUR_RECAPTCHA_SITE_KEY"
RECAPTCHA_SECRET_KEY="YOUR_RECAPTCHA_SECRET_KEY"

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL="info"
LOG_FILE="/var/log/election-portal/app.log"

# ===========================================
# SSL & SECURITY CONFIGURATION
# ===========================================
SSL_REDIRECT="true"

# ===========================================
# ADDITIONAL SECURITY SETTINGS
# ===========================================
# JWT Secret for additional security (if needed)
JWT_SECRET="CHANGE_THIS_TO_A_SECURE_RANDOM_STRING"

# Session configuration
SESSION_SECRET="CHANGE_THIS_TO_A_SECURE_RANDOM_STRING"

# ===========================================
# MONITORING & ANALYTICS (Optional)
# ===========================================
# Google Analytics (optional)
GOOGLE_ANALYTICS_ID=""

# Sentry for error tracking (optional)
SENTRY_DSN=""

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
BACKUP_ENABLED="true"
BACKUP_RETENTION_DAYS="30"

# ===========================================
# PERFORMANCE CONFIGURATION
# ===========================================
# Cache TTL in seconds
CACHE_TTL="3600"

# Database connection pool size
DB_POOL_SIZE="10"

# ===========================================
# DEVELOPMENT/DEBUG SETTINGS (Keep disabled in production)
# ===========================================
DEBUG="false"
VERBOSE_LOGGING="false"
